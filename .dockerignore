*.h5
*.hdf5
*.pt
*.pth
*.ckpt

# Abaikan raw data training yang tidak dibutuhkan API (notebook, excel mentah)
*.ipynb
*.xlsx

# Abaikan semua csv secara default, TAPI izinkan file yang dibutuhkan runtime API
*.csv
!baseline_payload_hourly_weekly.csv

# Abaikan file rahasia/kredensial lokal
.env
credentials.json