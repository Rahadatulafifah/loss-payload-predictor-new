# Abaikan folder Git (ini wajib agar image lebih ringan)
.git
.gitignore

# Abaikan Virtual Environment
venv/
.venv/
env/
ENV/

# Abaikan Cache Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Abaikan file konfigurasi editor
.vscode/
.idea/
.ipynb_checkpoints/

# Abaikan file sistem Mac & Windows
.DS_Store
Thumbs.db

